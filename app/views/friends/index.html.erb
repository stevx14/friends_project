
<% content_for :title, "Friends" %>
  <% if user_signed_in? %>
  <h1>Friends</h1>

  <table class="table table-striped table-bordered table-hover">
    <thead class="thead-dark">
      <tr>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Twitter</th>
        <th>User Id</th>
        <th>Actions</th>
        
      </tr>
    </thead>

    <tbody>

      <% @friends.each do |friend| %>
        <% if friend.user == current_user%>
        <tr>
          <td><%= friend.first_name %></td>
          <td><%= friend.last_name %></td>
          <td><%= friend.email %></td>
          <td><%= friend.phone %></td>
          <td><%= friend.instagram %></td>
          <td><%= friend.user_id %></td>
          <td>
            <%= link_to "Show", friend_path(friend), class:"btn btn-info" %> 
            <%= link_to "Edit", edit_friend_path(friend), class:"btn btn-warning" %> 
            <%= link_to "Delete", friend, data: { turbo_method: :delete, turbo_confirm:
              "Are you sure?" } , class:"btn btn-danger"%>
          </td>
        </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>

  <br>

  <%= link_to "Add New Friend", new_friend_path, class:"btn btn-outline-dark" %>
<% else %>

<div class="card">
  <h4 class="card-header">Welcome to Friends App</h4>
  <div class="card-body">
    
    <h5 class="card-text">Please create an Account or Log In to use the App</h5>
    <a href="users/sign_in" class="btn btn-outline-dark">Log In</a>
    <a href="users/sign_up" class="btn btn-outline-dark">Sign Up</a>
  </div>
</div>

<% end %>

